{
  "name": "appsumo-docs-mcp",
  "version": "1.0.1",
  "description": "MCP server for AppSumo licensing documentation",
  "keywords": [
    "mcp",
    "appsumo",
    "licensing",
    "webhooks",
    "documentation",
    "model-context-protocol"
  ],
  "type": "module",
  "bin": {
    "appsumo-docs-mcp": "bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "docs/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.server.json",
    "prepare": "npm run build",
    "scrape": "tsx src/scraper.ts",
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.5",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "playwright": "^1.60.0",
    "tsx": "^4.15.0",
    "turndown": "^7.2.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
